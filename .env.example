# Bot Configuration Get API Keys from @BotFather
BOT_TOKEN=
ADMIN_BOT_TOKEN=
ADMIN_USER_IDS=


# Local Bot API (For 2GB Uploads)
# Get these from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

LOCAL_API_URL=http://localhost:8081

# Features
ENABLE_CREDITS=true
ENABLE_REFERRALS=true
FREE_DAILY_LIMIT=10
REFERRAL_REWARD_CREDITS=5

# Download Settings
MAX_FILE_SIZE_MB=500
DEFAULT_VIDEO_QUALITY=720p
# Supported formats are configured in code, but valid output extensions are managed by yt-dlp

# Logging
LOG_LEVEL=INFO

